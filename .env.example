# EmailJS configuration
# Sign up at https://www.emailjs.com and get these values:
# 1. Create account -> Email Services -> Add Gmail (connect gokulsenthilkumar3@gmail.com)
# 2. Email Templates -> Create Template with variables:
#      From Name:    {{from_name}}
#      From Email:   {{from_email}}
#      Subject:      {{subject}}
#      Message:      {{message}}
# 3. Account -> General -> API Keys
#
# Copy this file to .env.local and fill in your values:

EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx
EMAILJS_PUBLIC_KEY=your_public_key_here
EMAILJS_PRIVATE_KEY=your_private_key_here
